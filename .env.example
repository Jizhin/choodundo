# --- Database ---
POSTGRES_USER=choodundo
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=choodundo

# --- Backend ---
# Comma-separated origins, or * for all. Set to your domain in production.
CORS_ORIGINS=*
ENVIRONMENT=production
DEBUG=false
UVICORN_WORKERS=2

# Geocoder (Photon). Public instance by default; for production, run the
# self-hosted `photon` service (see docker-compose.yml) and set:
# PHOTON_URL=http://photon:2322
PHOTON_URL=https://photon.komoot.io

# --- Edge ---
HTTP_PORT=80
